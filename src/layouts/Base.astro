---
import '../styles/theme.css';
import '../styles/reading.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0f1117" />
  <title>{title}</title>
  <!-- Favicons em todos os tamanhos -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
  <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
  <link rel="icon" href="/favicon-64x64.png" sizes="64x64" type="image/png" />
  <link rel="icon" href="/favicon-128x128.png" sizes="128x128" type="image/png" />
  <link rel="icon" href="/favicon-256x256.png" sizes="256x256" type="image/png" />
  <link rel="icon" href="/favicon-512x512.png" sizes="512x512" type="image/png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />
</head>
<body style="display: flex;">
  <!-- Sidebar do Starlight -->
  <aside style="width: 260px; min-height: 100vh; background: var(--kb-bg2); border-right: 1px solid var(--kb-border); position: fixed; top: 0; left: 0; overflow-y: auto; flex-direction: column; display: none;">
  </aside>

  <!-- Main content -->
  <div style="margin-left: 0; flex: 1;">
    <main style="max-width: 1200px; margin: 0 auto; padding: 48px 20px;">
      <slot />
    </main>
  </div>

  <style is:global>
    :root {
      --kb-bg: #0f1117;
      --kb-bg2: #161820;
      --kb-bg3: #1c1e27;
      --kb-bg4: #22242e;
      --kb-border: #2a2d3a;
      --kb-border2: #353848;
      --kb-text: #e2e4f0;
      --kb-text2: #9096b0;
      --kb-text3: #5a6080;
      --kb-accent: #6c7bff;
      --kb-accent2: #4facfe;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--kb-bg);
      color: var(--kb-text);
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 15px;
      line-height: 1.65;
      margin: 0;
      padding: 0;
    }

    @media (max-width: 800px) {
      main {
        padding: 32px 16px !important;
      }
    }
  </style>
</body>
</html>
