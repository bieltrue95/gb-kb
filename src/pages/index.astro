---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/Base.astro";

const docs = await getCollection("docs");
const docsBySlug = new Map(docs.map((doc) => [doc.slug, doc]));

// Seções e ordem exata dos artigos — mesma ordem da sidebar em astro.config.mjs
const sectionsConfig = [
  {
    name: "Padrões Distribuídos",
    slugs: [
      "distribuidos/strangler-fig",
      "distribuidos/feature-flags",
      "distribuidos/outbox",
      "distribuidos/saga",
      "distribuidos/resilience",
      "distribuidos/deferred-execution",
    ],
  },
  {
    name: "C# Fundamentals",
    slugs: [
      "csharp/polymorphism",
      "csharp/interfaces-vs-abstract",
      "csharp/collections-generics",
      "csharp/immutability",
      "csharp/delegates-events",
    ],
  },
  {
    name: "Async & Performance",
    slugs: ["async/linq", "async/async-await", "async/threading", "async/memory-span"],
  },
  {
    name: "Architecture & Design",
    slugs: [
      "arquitetura/dependency-injection",
      "dotnet/solid",
      "arquitetura/design-patterns",
      "arquitetura/cqrs",
      "dotnet/arquitetura",
      "dotnet/unit-of-work",
    ],
  },
  {
    name: "ASP.NET Core",
    slugs: [
      "aspnet/rest-api",
      "aspnet/middleware",
      "appsec/jwt-seguro",
      "appsec/owasp-top10",
      "aspnet/caching",
    ],
  },
  {
    name: "Data & EF Core",
    slugs: ["data/ef-core-basics", "dotnet/ef-core-performance"],
  },
  {
    name: "Testing & DevOps",
    slugs: [
      "devops/testing",
      "ferramentas/docker",
      "ferramentas/github-actions",
      "ferramentas/azure",
    ],
  },
  {
    name: "Messaging & Events",
    slugs: ["messaging/messaging-patterns", "messaging/rabbitmq"],
  },
  {
    name: "Segurança & Redes",
    slugs: [
      "appsec/broken-access-control",
      "appsec/burp-suite",
      "appsec/sast-semgrep",
      "appsec/threat-modeling",
      "appsec/security-headers",
      "redes/fundamentos",
    ],
  },
];

const sections = sectionsConfig
  .map((section) => ({
    name: section.name,
    docs: section.slugs.map((slug) => docsBySlug.get(slug)).filter((doc) => doc !== undefined),
  }))
  .filter((section) => section.docs.length > 0);

// Conta total de docs
const totalDocs = sections.reduce((sum, section) => sum + section.docs.length, 0);
---

<BaseLayout
  title="Knowledge Base · Gabriel"
  description="Guia completo de .NET, C#, ASP.NET Core, EF Core, arquitetura e padrões distribuídos"
>
  <div class="kb-home">
    <!-- Hero -->
    <div class="kb-hero">
      <div class="kb-logo-container">
        <img src="/gb-kb/favicon-256x256.png" alt="GB Logo" class="kb-logo" />
      </div>
      <div class="kb-eyebrow">⬡ C# & .NET Study Guide</div>
      <h1>Knowledge Base · Gabriel</h1>
      <p>
        Guia completo de .NET, C#, ASP.NET Core, EF Core, arquitetura e padrões distribuídos —
        referência de estudo e preparação técnica.
      </p>
      <div class="kb-stats">
        <div>
          <div class="kb-stat-num">{totalDocs}+</div>
          <div class="kb-stat-lbl">tópicos cobertos</div>
        </div>
        <div>
          <div class="kb-stat-num">34+</div>
          <div class="kb-stat-lbl">perguntas de entrevista</div>
        </div>
        <div>
          <div class="kb-stat-num">{sections.length}</div>
          <div class="kb-stat-lbl">áreas de estudo</div>
        </div>
      </div>
    </div>

    <!-- Study path -->
    <div class="kb-studypath">
      <h2>Caminho de estudo sugerido</h2>
      <div class="kb-steps">
        <div class="kb-step"><span class="kb-step-num">1</span>C# Fundamentals</div>
        <span class="kb-arrow">→</span>
        <div class="kb-step"><span class="kb-step-num">2</span>Async & Performance</div>
        <span class="kb-arrow">→</span>
        <div class="kb-step"><span class="kb-step-num">3</span>Architecture & Design</div>
        <span class="kb-arrow">→</span>
        <div class="kb-step"><span class="kb-step-num">4</span>ASP.NET & EF Core</div>
        <span class="kb-arrow">→</span>
        <div class="kb-step"><span class="kb-step-num">5</span>Padrões Distribuídos</div>
      </div>
    </div>

    <!-- Seções dinâmicas por categoria -->
    {
      sections.map((section) => (
        <div class="kb-section">
          <div class="kb-section-head">
            <h2>{section.name}</h2>
          </div>
          <div class="kb-cards">
            {section.docs.map((doc) => (
              <a class="kb-card" href={`/gb-kb/${doc.slug}/`}>
                <div class="kb-card-emoji">{doc.data.emoji || "📄"}</div>
                <div class="kb-card-title">{doc.data.title}</div>
                <div class="kb-card-desc">{doc.data.description}</div>
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</BaseLayout>

<style>
  /* CSS já definido em src/styles/theme.css */
</style>
