---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

const target = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/distribuidos/strangler-fig/`;
---

<StarlightPage
  frontmatter={{
    title: "Knowledge Base · Gabriel",
    template: "splash",
    head: [{ tag: "meta", attrs: { "http-equiv": "refresh", content: `0;url=${target}` } }],
  }}
>
  <p>
    Redirecionando para <a href={target}>o conteúdo da Knowledge Base</a>...
  </p>
</StarlightPage>

<script define:vars={{ target }}>
  window.location.replace(target);
</script>
